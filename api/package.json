{
  "name": "spriteforge-api",
  "version": "1.0.0",
  "description": "Headless API for generating pixel art sprites via AWS Lambda",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');['openapi.yaml','package.json','package-lock.json'].forEach(f=>fs.copyFileSync(f,'dist/'+f))\"",
    "start": "node dist/local.js",
    "package": "npm run build && cd dist && npm install --production"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@napi-rs/canvas": "^0.1.65",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.7.0"
  }
}
